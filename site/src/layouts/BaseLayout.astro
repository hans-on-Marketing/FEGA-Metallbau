---
import '@/styles/global.css';
import Nav from '@/components/islands/Nav.tsx';
import Footer from '@/components/Footer.astro';
import { COMPANY } from '@/data/content';
import { withBase } from '@/lib/url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  schemas?: Record<string, unknown>[]; // zusätzliche JSON-LD-Blöcke je Seite
}
const {
  title = COMPANY.legalLong,
  description = 'FEGA GmbH – Metallbau, Maschinenbau, Pumpentechnik, Maschinenhandel und Mietpark. Ein Lieferant für die Region Westerwald / Taunus. Gefertigt nach DIN EN 1090-2 · EXC 3.',
  ogImage = '/og-image.jpg',
  ogType = 'website',
  schemas = [],
} = Astro.props;

const site = Astro.site ?? new URL('https://hans-on-marketing.github.io');
// Voller Pfad inkl. base (für Canonical); base-bereinigter Pfad für den Nav-Active-State.
const fullPath = Astro.url.pathname;
const baseTrim = import.meta.env.BASE_URL.replace(/\/$/, '');
let navPath = baseTrim && fullPath.startsWith(baseTrim) ? fullPath.slice(baseTrim.length) : fullPath;
navPath = navPath.replace(/\/$/, '') || '/';
const canonical = new URL(fullPath, site).href;
const ogImageUrl = new URL(withBase(ogImage), site).href;

// Organization-Schema – ausschließlich gesicherte, öffentlich publizierte Daten.
// Keine Postanschrift/Telefon/Öffnungszeiten (unklar/uneinheitlich → s. OFFENE-PUNKTE.md).
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: COMPANY.legal,
  legalName: COMPANY.legalLong,
  url: site.href,
  logo: new URL(withBase('/fega-logo.png'), site).href,
  slogan: COMPANY.claim,
  description:
    'Metallbau, Maschinenbau (Schnellwechsel-Adapter nach DIN EN 1090-2 / EXC 3), Pumpentechnik, Maschinenhandel und Gerätevermietung aus einer Hand.',
  email: COMPANY.email,
  areaServed: COMPANY.region,
  knowsAbout: ['Metallbau', 'Maschinenbau', 'Pumpentechnik', 'Maschinenhandel', 'Gerätevermietung'],
  parentOrganization: { '@type': 'Organization', name: COMPANY.group },
};
---
<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={withBase("/fega-logo.png")} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href={withBase("/sitemap-index.xml")} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={COMPANY.legal} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {schemas.map((sc) => (
      <script type="application/ld+json" set:html={JSON.stringify(sc)} />
    ))}
  </head>
  <body>
    <div style="display:flex;flex-direction:column;min-height:100vh;background:#fff;">
      <Nav client:load path={navPath} />
      <main style="flex:1;">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
