---
/* ============================================================================
   FEGA — Startseite 2026 (Relaunch). Kino-Hero + 11 Sektionen.
   Footer + Unterseiten unverändert. Design-Handoff: design_handoff_startseite.
   ========================================================================== */
import BaseLayout from '@/layouts/BaseLayout.astro';
import OptImage from '@/components/OptImage.astro';
import Stat from '@/components/islands/Stat.tsx';
import { COMPANY, SERVICES, ABOUT, GROUP, JOBS, REFERENCES, SLUG } from '@/data/content';
import { withBase } from '@/lib/url';

const SVC_IMG2: Record<string, string> = {
  maschinenbau: 'adapter-detail.jpg',
  metallbau: 'metallbau-ueberdachung.jpg',
  pumpentechnik: 'werkstatt.jpg',
  maschinenhandel: 'handel-umschlag.jpg',
  mietpark: 'mietgeraet.jpg',
};
const SVC_POS: Record<string, string> = {
  maschinenbau: 'center 60%', metallbau: 'center 70%', pumpentechnik: 'center 55%', maschinenhandel: 'center', mietpark: 'center',
};
const fegaJobs = JOBS.filter((j) => j.company === 'FEGA');
const refItems = [REFERENCES[2], REFERENCES[1], REFERENCES[3], REFERENCES[4], REFERENCES[7], REFERENCES[6]];
const link = (id: string) => withBase(SLUG[id]);
---
<BaseLayout
  title="FEGA GmbH – Solide Leistung, die man kaufen kann | Metallbau & Maschinenbau"
  description="FEGA GmbH aus dem Westerwald: Geräteadapter nach DIN EN 1090-2 / EXC 3, Metallbau, Pumpenprüfung, Maschinenhandel und Gerätemiete. Alles aus einer Hand — Angebot in der Regel innerhalb von 24 Stunden."
>
  <div class="h2026">
    <!-- 1 · HERO (cinematic, full-bleed) -->
    <section class="hk" data-screen-label="hero">
      <div class="hk__media">
        <OptImage name="hero-team.jpg" dark cover position="center 32%" loading="eager" fetchpriority="high" sizes="100vw" style="position:absolute;inset:0;width:100%;height:100%;" />
      </div>
      <div class="hk__scrim"></div>
      <div class="kc hk__inner">
        <div style="max-width:1000px;">
          <span class="eye eye--dark"><span class="eye__tick"></span><span class="eye__txt">FEGA GmbH · Metallbau · seit {COMPANY.since}</span></span>
          <h1 class="hk__title">Solide Leistung,<br />die man kaufen kann.</h1>
          <p class="hk__lead">Geräteadapter nach Norm, Metallbau, Pumpenprüfung und Gerätemiete — gefertigt und geprüft im {COMPANY.region}. Alles aus einer Hand.</p>
          <div class="hk__cta">
            <a class="btn btn--primary btn--lg" href={withBase('/kontakt')}>Anfrage stellen</a>
            <a class="btn btn--line-d btn--lg" href="#leistungen">Unsere Leistungen</a>
          </div>
        </div>
      </div>
    </section>

    <!-- 2 · LEISTUNGS-INDEX -->
    <section class="sec" style="background:var(--paper);padding:clamp(40px,5.5vw,76px) 0;">
      <div class="kc">
        <div class="idx">
          {SERVICES.map((s) => (
            <a class="idx__row" href={link(s.id)}>
              <span class="idx__no">{s.no}</span>
              <span class="idx__label">{s.label}</span>
              <span class="idx__kicker">{s.kicker}</span>
              <span class="idx__badge">{(s.badges && s.badges[0]) || ''}</span>
              <span class="idx__arrow">&#8594;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 3 · PRODUKTBAND „Deutsche Ingenieurskunst" (navy, full-bleed) -->
    <section class="band" data-screen-label="ingenieurskunst">
      <div class="band__media" aria-hidden="true">
        <span class="band__bar" style="left:-6%;width:12%;background:#0A0A0A;"></span>
        <span class="band__bar" style="left:7%;width:14%;background:var(--red);"></span>
        <span class="band__bar" style="left:24%;width:22%;background:var(--blue);"></span>
        <span class="band__bar" style="left:50%;width:6%;background:rgba(255,255,255,0.06);"></span>
        <span class="band__vignette"></span>
        <div class="band__cut">
          <div class="band__ph">
            <div class="band__ph-diamond"></div>
            <div class="band__ph-l">Produkt-Freisteller</div>
            <div class="band__ph-s">Bildplatz</div>
          </div>
        </div>
      </div>
      <div class="band__text">
        <div style="max-width:560px;">
          <span class="eye eye--dark"><span class="eye__tick eye__tick--sq"></span><span class="eye__txt">Made in Germany · Maschinenbau</span></span>
          <h2 class="band__h2">Deutsche Ingenieurskunst<br />aus dem Westerwald</h2>
          <p class="band__p1">Vom Schnellwechsel-Adapter bis zur kompletten Anbaukonstruktion: Wir entwickeln und fertigen Metalllösungen nach DIN EN 1090-2 / EXC 3 — präzise, dokumentiert und für den harten Dauereinsatz gebaut.</p>
          <p class="band__p2">Seit {COMPANY.since} entsteht bei FEGA im {COMPANY.region} Maschinenbau, der hält — Konstruktion, Fertigung und Prüfung aus einer Hand.</p>
          <div class="band__cta">
            <a class="btn btn--primary btn--md" href={withBase('/kontakt')}>Anfrage stellen</a>
            <a class="btn btn--line-d btn--md" href={link('maschinenbau')}>Zum Maschinenbau</a>
          </div>
        </div>
      </div>
    </section>

    <!-- 4 · INTRO / Wer wir sind -->
    <section class="sec" id="ueber-uns" style="background:var(--s1);">
      <div class="kc">
        <div class="intro">
          <div>
            <span class="eye"><span class="eye__tick"></span><span class="eye__txt">Wer wir sind</span></span>
            <h2 class="h2">Ein Lieferant.<br />Keine Kompromisse.</h2>
            <p class="lead">FEGA fertigt, prüft und liefert — Geräteadapter nach DIN EN 1090-2 / EXC 3, Metallbau, Pumpenservice und Gerätemiete. Direkt aus dem {COMPANY.region}, seit {COMPANY.since}. Koordiniert aus einer Hand, dokumentiert und termintreu.</p>
            <a class="arrow" href={withBase('/ueber-uns')}>Über das Unternehmen <span class="arrow__a">&#8594;</span></a>
          </div>
          <div class="intro__stats">
            {ABOUT.stats.map((s, i) => <Stat client:visible v={s.v} l={s.l} color={i === 2 ? '#006DB6' : '#16161A'} />)}
          </div>
        </div>
      </div>
    </section>

    <!-- 5 · LEISTUNGEN IM BILD (Foto-Mosaik) -->
    <section class="sec" id="leistungen" style="background:var(--white);">
      <div class="kc">
        <div class="head">
          <div style="max-width:640px;">
            <span class="eye"><span class="eye__tick"></span><span class="eye__txt">Leistungen im Bild</span></span>
            <h2 class="h2">Was wir fertigen.</h2>
          </div>
          <p class="head__intro">Fünf Bereiche aus einer Hand — koordiniert, dokumentiert, termintreu.</p>
        </div>
        <div class="mos mos--top">
          {[SERVICES[0], SERVICES[1], SERVICES[2]].map((s) => (
            <a class="tile" href={link(s.id)} style="height:400px;">
              <OptImage name={SVC_IMG2[s.id]} dark cover position={SVC_POS[s.id]} sizes="(max-width:880px) 100vw, 40vw" style="position:absolute;inset:0;width:100%;height:100%;" />
              <span class="tile__grad"></span>
              <span class="tile__body">
                <span class="tile__meta"><span class="tile__sq"></span><span class="tile__no">{s.no}</span></span>
                <span class="tile__label">{s.label}</span>
                <span class="tile__kicker">{s.kicker}</span>
              </span>
            </a>
          ))}
        </div>
        <div class="mos mos--bot">
          {[SERVICES[3], SERVICES[4]].map((s) => (
            <a class="tile" href={link(s.id)} style="height:300px;">
              <OptImage name={SVC_IMG2[s.id]} dark cover position={SVC_POS[s.id]} sizes="(max-width:880px) 100vw, 33vw" style="position:absolute;inset:0;width:100%;height:100%;" />
              <span class="tile__grad"></span>
              <span class="tile__body">
                <span class="tile__meta"><span class="tile__sq"></span><span class="tile__no">{s.no}</span></span>
                <span class="tile__label">{s.label}</span>
                <span class="tile__kicker">{s.kicker}</span>
              </span>
            </a>
          ))}
          <a class="tile-cta" href={withBase('/kontakt')} style="height:300px;">
            <div>
              <div class="tile-cta__eye">Beratung</div>
              <div class="tile-cta__t">Noch unklar, was Sie brauchen?</div>
            </div>
            <span class="tile-cta__more">Anfrage stellen <span class="arrow__a">&#8594;</span></span>
          </a>
        </div>
      </div>
    </section>

    <!-- 6 · ADAPTER-FEATURE (Flaggschiff) -->
    <section class="sec" style="background:var(--s1);">
      <div class="kc">
        <div class="adp">
          <div>
            <span class="eye"><span class="eye__tick"></span><span class="eye__txt">Flaggschiff · seit 2019</span></span>
            <h2 class="h2">Schnellwechsel-Adapter, die exakt passen.</h2>
            <p class="lead" style="max-width:520px;">Wir fertigen und vertreiben Adapter für diverse Erdbewegungsmaschinen — nach DIN EN 1090-2 / EXC 3 und Maschinenrichtlinie 2006/42/EG. Gewichtsoptimiert, präzise, langlebig.</p>
            <dl class="spec">
              <div class="spec__row"><dt>Norm</dt><dd>DIN EN 1090-2 · EXC 3</dd></div>
              <div class="spec__row"><dt>Richtlinie</dt><dd>Maschinenrichtlinie 2006/42/EG</dd></div>
              <div class="spec__row"><dt>Systeme</dt><dd>Mechanisch & hydraulisch</dd></div>
            </dl>
            <a class="arrow" href={link('maschinenbau')}>Zum Maschinenbau <span class="arrow__a">&#8594;</span></a>
          </div>
          <div class="adp__collage">
            <div style="grid-row:1 / span 2;">
              <OptImage name="adapter-produkt.jpg" ratio="3/4.1" position="center" sizes="(max-width:900px) 60vw, 30vw" />
            </div>
            <OptImage name="adapter-baustelle.jpg" ratio="4/3" position="center 45%" sizes="(max-width:900px) 40vw, 22vw" />
            <div class="adp__exc">
              <div class="adp__exc-v">EXC&nbsp;3</div>
              <div class="adp__exc-l">Fertigungsklasse</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 7 · VERTRAUEN / Einkäufer-Argumente -->
    <section class="sec" style="background:var(--white);padding:clamp(56px,7vw,104px) 0;">
      <div class="kc">
        <div class="trust">
          {COMPANY.buyerPoints.map((b, i) => (
            <div class="trust__item" style={`border-left:2px solid ${i === 0 ? 'var(--blue)' : 'var(--lineMid)'};`}>
              <div class="trust__no">{String(i + 1).padStart(2, '0')}</div>
              <div class="trust__t">{b[0]}</div>
              <div class="trust__d">{b[1]}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 8 · UNTERNEHMENSGRUPPE (dunkel) -->
    <section class="sec" id="feickert" style="background:var(--char);color:#fff;">
      <div class="kc">
        <div class="grp">
          <div style="position:relative;">
            <OptImage name="feickert-bagger.jpg" dark ratio="4/3" position="center" sizes="(max-width:900px) 100vw, 48vw" />
            <div class="tribar"><i></i><i></i><i></i></div>
          </div>
          <div>
            <span class="eye eye--dark"><span class="eye__tick" style="background:var(--blue);"></span><span class="eye__txt">Unternehmensgruppe</span></span>
            <h2 class="h2 h2--dark">Wir leben Bau.<br />Seit drei Generationen.</h2>
            <p class="lead lead--dark" style="max-width:480px;">FEGA gehört zur {GROUP.name} mit Sitz in {GROUP.seat}. Seit 1947 in dritter Generation zu 100 % in Familienhand — mit Tiefbau und Spezialtiefbau im gesamten Bundesgebiet.</p>
            <div class="grp__stats">
              {GROUP.facts.slice(0, 3).map((f, i) => <Stat client:visible v={f.v} l={f.l} onDark color={i === 0 ? '#006DB6' : '#fff'} />)}
            </div>
            <a class="arrow arrow--dark" href={withBase('/unternehmensgruppe')}>Mehr zur Unternehmensgruppe <span class="arrow__a">&#8594;</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- 9 · REFERENZEN -->
    <section class="sec" id="referenzen" style="background:var(--s1);">
      <div class="kc">
        <div class="head head--row">
          <div>
            <span class="eye"><span class="eye__tick"></span><span class="eye__txt">Referenzen</span></span>
            <h2 class="h2">Ausgewählte Arbeiten.</h2>
          </div>
          <a class="arrow" href={withBase('/referenzen')}>Alle Referenzen <span class="arrow__a">&#8594;</span></a>
        </div>
        <div class="refs">
          {refItems.map((r) => (
            <a class="ref" href={withBase('/referenzen')}>
              <div class="ref__media"><OptImage name={r.img} ratio="4/3" position="center" sizes="(max-width:1040px) 50vw, 33vw" /></div>
              <div class="ref__meta"><span class="ref__sq"></span><span class="ref__cat">{r.cat}</span></div>
              <div class="ref__t">{r.t}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 10 · KARRIERE -->
    <section class="sec" id="karriere" style="background:var(--white);">
      <div class="kc">
        <div class="kar">
          <OptImage name="werkstatt.jpg" ratio="4/5" position="center" sizes="(max-width:900px) 100vw, 40vw" />
          <div>
            <span class="eye"><span class="eye__tick" style="background:var(--red);"></span><span class="eye__txt">Karriere</span></span>
            <h2 class="h2">Hands-on gesucht.</h2>
            <p class="lead" style="max-width:500px;">Schweißen, montieren, konstruieren — bei FEGA arbeitest du an Teilen, die auf echten Baustellen stehen. Kein Schreibtisch. Echte Arbeit.</p>
            <div class="kar__jobs">
              {fegaJobs.map((j) => (
                <a class="job" href={withBase('/karriere')}>
                  <span>
                    <span class="job__t">{j.title} <span class="job__mwd">({j.mwd})</span></span>
                    <span class="job__type">{j.type}</span>
                  </span>
                  <span class="job__arrow">&#8594;</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 11 · KONTAKT / CTA -->
    <section class="sec" id="kontakt" style="background:var(--s1);padding:clamp(56px,7vw,104px) 0;">
      <div class="kc">
        <div class="cta">
          <div>
            <span class="eye"><span class="eye__tick"></span><span class="eye__txt">Kontakt</span></span>
            <h2 class="h2">Dann reden wir jetzt.</h2>
            <p class="lead" style="max-width:540px;">Adapter. Metallbau. Pumpen. Miete. Angebot in der Regel innerhalb von 24 Stunden — ohne Warteschleife.</p>
          </div>
          <div class="cta__btns">
            <a class="btn btn--primary btn--lg" href={withBase('/kontakt')}>Anfrage stellen</a>
            <a class="btn btn--line btn--lg" href={COMPANY.phoneHref}>{COMPANY.phone}</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>
  html { scroll-behavior: smooth; }
</style>

<style>
  .h2026 {
    --paper: #FBFBFC;
    --s1: #F3F3F5;
    --white: #FFFFFF;
    --char: #141417;
    --navy: #0E2A4A;
    --ink: #16161A;
    --ink2: #34343C;
    --sub: #5C5C66;
    --faint: #9A9AA4;
    --faint2: #B7B7C0;
    --line: #E2E2E6;
    --lineMid: #D2D2D8;
    --lineStrong: #B9B9C1;
    --blue: #006DB6;
    --blueDk: #005A99;
    --red: #EE413E;
    --fp: var(--font-primary);
    --fm: var(--font-mono);
    background: var(--white);
  }
  .kc { max-width: 1380px; margin: 0 auto; padding: 0 clamp(20px, 4.5vw, 72px); width: 100%; }
  .sec { padding: clamp(72px, 9vw, 148px) 0; scroll-margin-top: 84px; }

  /* Eyebrow */
  .eye { display: inline-flex; align-items: center; gap: 11px; }
  .eye__tick { width: 18px; height: 2px; background: var(--blue); flex-shrink: 0; }
  .eye__tick--sq { width: 7px; height: 7px; }
  .eye__txt { font-family: var(--fm); font-size: 11.5px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--sub); }
  .eye--dark .eye__txt { color: rgba(255,255,255,0.72); }

  /* Headings + leads */
  .h2 { margin-top: 22px; font-family: var(--fp); font-size: clamp(28px,3.5vw,52px); font-weight: 700; letter-spacing: -0.025em; line-height: 1.03; color: var(--ink); text-wrap: balance; }
  .h2--dark { color: #fff; }
  .lead { margin-top: 24px; max-width: 560px; font-family: var(--fp); font-weight: 400; font-size: clamp(16px,1.3vw,19px); line-height: 1.68; color: var(--sub); }
  .lead--dark { color: rgba(255,255,255,0.72); }

  /* Buttons */
  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; font-family: var(--fp); font-weight: 600; letter-spacing: 0.02em; border-radius: 0; cursor: pointer; text-decoration: none; white-space: nowrap; transition: background .18s, color .18s, border-color .18s; }
  .btn--md { height: 50px; padding: 0 26px; font-size: 13.5px; }
  .btn--lg { height: 56px; padding: 0 32px; font-size: 14px; }
  .btn--primary { background: var(--blue); color: #fff; border: 1px solid var(--blue); }
  .btn--primary:hover { background: var(--blueDk); border-color: var(--blueDk); }
  .btn--line { background: transparent; color: var(--ink); border: 1px solid var(--lineStrong); }
  .btn--line:hover { background: var(--ink); color: #fff; }
  .btn--line-d { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.45); }
  .btn--line-d:hover { background: rgba(255,255,255,0.10); }

  /* Arrow link */
  .arrow { display: inline-flex; align-items: center; gap: 10px; font-family: var(--fp); font-size: 13.5px; font-weight: 600; letter-spacing: 0.02em; color: var(--ink); text-decoration: none; }
  .arrow--dark { color: #fff; }
  .arrow:hover > :first-child { box-shadow: inset 0 -1px 0 currentColor; }
  .arrow__a { color: var(--blue); display: inline-block; transition: transform .26s cubic-bezier(.2,.7,.2,1); }
  .arrow:hover .arrow__a { transform: translateX(5px); }

  /* 1 · Hero */
  .hk { position: relative; min-height: min(calc(100vh - 78px), 940px); display: flex; align-items: flex-end; background: var(--char); overflow: hidden; }
  .hk__media { position: absolute; inset: 0; overflow: hidden; }
  .hk__media :global(img) { filter: saturate(0.9) contrast(1.03) brightness(0.96); }
  .hk__scrim { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(8,8,10,0.42) 0%, rgba(8,8,10,0) 26%, rgba(8,8,10,0.10) 55%, rgba(8,8,10,0.78) 100%); }
  .hk__inner { position: relative; z-index: 2; padding-top: clamp(48px,7vh,96px); padding-bottom: clamp(54px,6vw,104px); }
  .hk__title { margin-top: 26px; font-family: var(--fp); font-weight: 700; font-size: clamp(46px,7.4vw,112px); letter-spacing: -0.035em; line-height: 0.95; color: #fff; text-wrap: balance; }
  .hk__lead { margin-top: 28px; max-width: 560px; font-family: var(--fp); font-weight: 400; font-size: clamp(16px,1.35vw,20px); line-height: 1.6; color: rgba(255,255,255,0.82); }
  .hk__cta { margin-top: 38px; display: flex; gap: 13px; flex-wrap: wrap; }

  /* 2 · Index */
  .idx { border-top: 2px solid var(--ink); }
  .idx__row { display: grid; grid-template-columns: 60px 1.1fr 1.4fr 90px 30px; gap: 24px; align-items: center; padding: 22px 8px; border-bottom: 1px solid var(--line); text-decoration: none; transition: background .16s; }
  .idx__row:hover { background: var(--white); }
  .idx__no { font-family: var(--fm); font-size: 13px; color: var(--faint2); transition: color .2s; }
  .idx__row:hover .idx__no { color: var(--blue); }
  .idx__label { font-family: var(--fp); font-size: clamp(19px,2vw,26px); font-weight: 600; letter-spacing: -0.015em; color: var(--ink); transition: transform .25s; }
  .idx__row:hover .idx__label { transform: translateX(6px); }
  .idx__kicker { font-family: var(--fp); font-size: 13.5px; font-weight: 400; color: var(--sub); line-height: 1.4; }
  .idx__badge { font-family: var(--fm); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--faint); justify-self: start; }
  .idx__arrow { justify-self: end; font-family: var(--fp); font-size: 20px; color: var(--faint2); transition: color .25s, transform .25s; }
  .idx__row:hover .idx__arrow { color: var(--blue); transform: translateX(4px); }

  /* 3 · Navy band */
  .band { background: var(--navy); color: #fff; display: grid; grid-template-columns: 0.86fr 1.14fr; align-items: stretch; }
  .band__media { position: relative; overflow: hidden; min-height: clamp(400px,42vw,560px); border-right: 1px solid rgba(255,255,255,0.08); }
  .band__bar { position: absolute; top: -30%; height: 160%; transform: rotate(20deg); transform-origin: center; }
  .band__vignette { position: absolute; inset: 0; background: radial-gradient(120% 90% at 32% 50%, rgba(14,42,74,0) 42%, rgba(14,42,74,0.5) 100%); }
  .band__cut { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding: 44px clamp(28px,4vw,72px); }
  .band__ph { width: min(80%,420px); aspect-ratio: 4/3; display: flex; flex-direction: column; align-items: center; justify-content: center; background: repeating-linear-gradient(135deg, rgba(255,255,255,0.06) 0 15px, rgba(255,255,255,0.12) 15px 30px); border: 1px solid rgba(255,255,255,0.22); text-align: center; }
  .band__ph-diamond { width: 18px; height: 18px; border: 1.5px solid rgba(255,255,255,0.5); transform: rotate(45deg); margin-bottom: 10px; }
  .band__ph-l { font-family: var(--fm); font-size: 10.5px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.72); }
  .band__ph-s { margin-top: 5px; font-family: var(--fm); font-size: 9.5px; letter-spacing: 0.08em; color: rgba(255,255,255,0.4); }
