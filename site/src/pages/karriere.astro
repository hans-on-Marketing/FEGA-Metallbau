---
/* ============================================================================
   FEGA — Karriere-Seite (Relaunch 2026, Design-Handoff). DU-Ansprache.
   12 Sektionen. Kino-Header (global) + bestehender Footer bleiben unverändert.
   ========================================================================== */
import BaseLayout from '@/layouts/BaseLayout.astro';
import OptImage from '@/components/OptImage.astro';
import Stat from '@/components/islands/Stat.tsx';
import KJobs from '@/components/islands/KJobs.tsx';
import KFaq from '@/components/islands/KFaq.tsx';
import { KARRIERE, COMPANY, JOBS, AUSBILDUNG } from '@/data/content';
import { withBase } from '@/lib/url';

const k = KARRIERE;
const MAIL = k.contact.email; // bewerbung@feickert-bau.de
const jobs = JOBS.map((j) => ({ id: j.id, title: j.title, mwd: j.mwd, type: j.type, ort: j.ort, company: j.company, intro: j.intro, aufgaben: j.aufgaben, profil: j.profil, benefits: j.benefits, external: j.external }));
const pathHref = (action: string) => (action === 'mail' ? `mailto:${MAIL}` : '#stellen');

// SEO: JobPosting (FEGA-Stellen) + FAQPage
const site = Astro.site ?? new URL('https://hans-on-marketing.github.io');
const datePosted = new Date().toISOString().slice(0, 10);
const empType = (t: string) => (t === 'Teilzeit' ? 'PART_TIME' : 'FULL_TIME');
const jobSchemas = JOBS.filter((j) => j.company === 'FEGA').map((j) => ({
  '@context': 'https://schema.org', '@type': 'JobPosting',
  title: `${j.title} (${j.mwd})`,
  description: [j.intro || j.desc, j.aufgaben?.length ? 'Aufgaben: ' + j.aufgaben.join('; ') + '.' : ''].filter(Boolean).join(' '),
  datePosted, employmentType: empType(j.type),
  hiringOrganization: { '@type': 'Organization', name: COMPANY.legal, sameAs: site.href },
  jobLocation: { '@type': 'Place', address: { '@type': 'PostalAddress', addressLocality: j.ort, addressCountry: 'DE' } },
}));
const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: k.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---
<BaseLayout
  title="Karriere bei FEGA: Metallbauer, Schweißer & Ausbildung (m/w/d) | Weilburg"
  description="Hands-on gesucht: Metallfacharbeiter, Schweißer/Schlosser und Ausbildung zum Metallbauer (m/w/d) in Weilburg/Lahn — plus Stellen der Feickert-Gruppe. Schnellbewerbung direkt an der Stelle."
  schemas={[...jobSchemas, faqSchema]}
>
  <div class="kar2026">
    <!-- 1 · HERO -->
    <section class="khero" id="hero" data-screen-label="hero">
      <div class="khero__media"><OptImage name="werkstatt.jpg" dark cover position="center 40%" loading="eager" fetchpriority="high" sizes="100vw" style="position:absolute;inset:0;width:100%;height:100%;" /></div>
      <div class="khero__scrim"></div>
      <div class="kc khero__inner">
        <div style="max-width:880px;">
          <span class="eye eye--red eye--dark"><span class="tick"></span><span class="lbl">{k.hero.overline}</span></span>
          <h1 class="khero__title">{k.hero.title}</h1>
          <p class="khero__lead">{k.hero.lead}</p>
          <div class="khero__cta">
            <a class="btn btn--primary btn--lg" href="#stellen">Offene Stellen ansehen</a>
            <a class="btn btn--line-d btn--lg" href={`mailto:${MAIL}`}>Initiativbewerbung</a>
          </div>
          <div class="khero__trust">
            {k.hero.trust.map((tr, i) => (
              <>{i > 0 && <span class="dot"></span>}<span class="tlbl">{tr}</span></>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 2 · ARBEITGEBER-ZAHLEN -->
    <section class="sec" id="arbeitgeber" style="background:var(--s1);">
      <div class="kc">
        <div class="fhead">
          <div style="max-width:560px;">
            <span class="eye"><span class="tick"></span><span class="lbl">FEGA als Arbeitgeber</span></span>
            <h2 class="h2">Solide Arbeit.<br />Solides Umfeld.</h2>
          </div>
          <p class="fhead__p">Ein Familienbetrieb mit dem Rückhalt einer der führenden Tiefbaugruppen Deutschlands — und Platz für Leute, die anpacken.</p>
        </div>
        <div class="facts">
          {k.facts.map((f, i) => (
            <div class="fact">
              <span class="fact__bar" style={`background:${i % 2 ? 'var(--red)' : 'var(--blue)'};`}></span>
              <Stat client:visible v={f.v} l={f.l} color={i === 0 ? '#006DB6' : '#16161A'} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3 · WARUM FEGA -->
    <section class="sec" id="warum" style="background:var(--white);">
      <div class="kc">
        <div style="max-width:640px;">
          <span class="eye eye--red"><span class="tick"></span><span class="lbl">Warum FEGA</span></span>
          <h2 class="h2">Warum du bei uns richtig bist.</h2>
          <p class="lead">Kein anonymer Konzern, kein Schreibtischjob: FEGA verbindet echtes Handwerk mit der Stabilität einer großen Unternehmensgruppe.</p>
        </div>
        <div class="grid3">
          {k.pillars.map((p) => (
            <div class="stepcard">
              <div class="stepcard__no">{p.no}</div>
              <h3 class="stepcard__t">{p.t}</h3>
              <p class="stepcard__d">{p.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4 · BENEFITS -->
    <section class="sec" id="benefits" style="background:var(--s1);">
      <div class="kc">
        <div style="max-width:640px;">
          <span class="eye eye--red"><span class="tick"></span><span class="lbl">Benefits</span></span>
          <h2 class="h2">Was dich bei FEGA erwartet.</h2>
          <p class="lead">Faire Bedingungen, moderne Ausstattung und die Sicherheit eines Familienbetriebs mit Gruppen-Rückhalt.</p>
        </div>
        <div class="benefits">
          {k.benefits.map((b) => (
            <div class="bcard">
              <span class="bcard__dia"></span>
              <div>
                <div class="bcard__t">{b.t}</div>
                <div class="bcard__d">{b.d}</div>
              </div>
            </div>
          ))}
        </div>
        <p class="benefits__note">Beispielhafte Leistungen — finale Auflistung nach Abstimmung mit der Personalabteilung.</p>
      </div>
    </section>

    <!-- 5 · SLOGAN-BREAK -->
    <section class="kslogan" id="slogan" data-screen-label="slogan">
      <div class="kslogan__media"><OptImage name="fertigung-rahmen.jpg" dark cover position="center" sizes="100vw" style="position:absolute;inset:0;width:100%;height:100%;" /></div>
      <div class="kslogan__scrim"></div>
      <div class="kc kslogan__inner">
        <div class="kslogan__eye"><span class="kslogan__stroke"></span><span class="kslogan__lbl">Made by Hand · Westerwald</span><span class="kslogan__stroke"></span></div>
        <h2 class="kslogan__h2">Funken fliegen.<br />Ergebnisse bleiben.</h2>
        <div style="margin-top:34px;display:flex;justify-content:center;"><a class="btn btn--line-d btn--lg" href="#stellen">Zu den offenen Stellen</a></div>
      </div>
    </section>

    <!-- 6 · WEGE -->
    <section class="sec" id="wege" style="background:var(--white);">
      <div class="kc">
        <div style="max-width:640px;">
          <span class="eye eye--red"><span class="tick"></span><span class="lbl">Einstieg & Ausbildung</span></span>
          <h2 class="h2">Dein Weg zu FEGA.</h2>
          <p class="lead">Ob mit Berufserfahrung, frisch von der Schule oder als Quereinsteiger — für jeden Weg gibt es bei uns eine Tür.</p>
        </div>
        <div class="grid3">
          {k.paths.map((p) => (
            <div class={`pcard${p.featured ? ' pcard--feat' : ''}`}>
              <span class="pcard__tag"><span class="pcard__dia"></span>{p.tag}</span>
              <h3 class="pcard__t">{p.t}</h3>
              <p class="pcard__d">{p.d}</p>
              <a class="pcard__cta" href={pathHref(p.action)}>{p.cta} <span class="arr">&#8594;</span></a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 7 · OFFENE STELLEN -->
    <section class="sec" id="stellen" style="background:var(--s1);">
      <div class="kc">
        <div class="shead">
          <div>
            <span class="eye eye--red"><span class="tick"></span><span class="lbl">Offene Stellen</span></span>
            <h2 class="h2">Jetzt einsteigen.</h2>
          </div>
          <div class="shead__count">{jobs.length} Stellen · FEGA &amp; Feickert-Gruppe</div>
        </div>
        <KJobs client:visible jobs={jobs} />
      </div>
    </section>

    <!-- 8 · AUSBILDUNG BEI FEICKERT -->
    <section class="sec" id="ausbildung-feickert" style="background:var(--char);color:#fff;">
      <div class="kc">
        <div class="fband">
          <div style="position:relative;">
            <OptImage name="feickert-bagger.jpg" dark ratio="4/3" position="center" sizes="(max-width:900px) 100vw, 48vw" />
            <div class="tribar"><i></i><i></i><i></i></div>
          </div>
          <div>
            <span class="eye eye--dark"><span class="tick" style="background:var(--blue);"></span><span class="lbl">Muttergesellschaft</span></span>
            <h2 class="h2 h2--dark">Die Ausbildung bei Feickert.</h2>
            <p class="lead lead--dark" style="max-width:480px;">{AUSBILDUNG.parentNote}</p>
            <div style="margin-top:30px;"><a class="btn btn--line-d btn--md" href={withBase('/ausbildung')}>Zur Ausbildung bei Feickert</a></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 9 · BEWERBUNGSPROZESS -->
    <section class="sec" id="prozess" style="background:var(--white);">
      <div class="kc">
        <div style="max-width:640px;">
          <span class="eye eye--red"><span class="tick"></span><span class="lbl">Bewerbung</span></span>
          <h2 class="h2">So läuft deine Bewerbung.</h2>
          <p class="lead">Unkompliziert und schnell — in vier Schritten vom Lebenslauf zum ersten Arbeitstag.</p>
        </div>
        <div class="grid4">
          {k.process.map((s) => (
            <div class="stepcard">
              <div class="stepcard__no">{s.no}</div>
              <h3 class="stepcard__t">{s.t}</h3>
              <p class="stepcard__d">{s.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 10 · ANSPRECHPARTNER -->
    <section class="sec" id="ansprechpartner" style="background:var(--s1);">
      <div class="kc">
        <div class="kkontakt">
          <div class="kkontakt__media">
            <div class="kkontakt__ph">Foto Ansprechpartner/in</div>
            <span class="kkontakt__stroke"></span>
          </div>
          <div class="kkontakt__body">
            <span class="eye eye--red"><span class="tick"></span><span class="lbl">Dein Kontakt</span></span>
            <h2 class="h2">Fragen? Sprich uns an.</h2>
            <div class="kkontakt__name">{k.contact.name}</div>
            <div class="kkontakt__role">{k.contact.role}</div>
            <p class="lead" style="max-width:460px;">{k.contact.note}</p>
            <div class="kkontakt__btns">
              <a class="btn btn--primary btn--md" href={k.contact.phoneHref}>{k.contact.phone}</a>
              <a class="btn btn--line btn--md" href={`mailto:${MAIL}`}>{MAIL}</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 11 · FAQ -->
    <section class="sec" id="faq" style="background:var(--white);">
      <div class="kc">
        <div class="kfaq">
          <div>
            <span class="eye eye--red"><span class="tick"></span><span class="lbl">FAQ</span></span>
            <h2 class="h2">Häufige Fragen zur Bewerbung.</h2>
            <p class="lead" style="max-width:380px;">Noch etwas offen? <a class="ilink" href={`mailto:${MAIL}`}>Schreib uns.</a></p>
          </div>
          <KFaq client:visible items={k.faq} />
        </div>
      </div>
    </section>

    <!-- 12 · CTA -->
    <section class="sec sec--sm" id="cta" style="background:var(--s1);">
      <div class="kc">
        <div class="kcta">
          <h2 class="h2" style="max-width:620px;">Bereit für den nächsten Schritt?</h2>
          <div style="display:flex;gap:13px;flex-wrap:wrap;">
            <a class="btn btn--primary btn--lg" href="#stellen">Offene Stellen ansehen</a>
            <a class="btn btn--line btn--lg" href={`mailto:${MAIL}`}>Initiativbewerbung</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>html{scroll-behavior:smooth}</style>

<style>
  .kar2026{
    --ink:#16161A;--ink2:#34343C;--sub:#5C5C66;--faint:#9A9AA4;--faint2:#B7B7C0;
    --line:#E2E2E6;--lineMid:#D2D2D8;--lineStrong:#B9B9C1;--s1:#F3F3F5;--white:#FFFFFF;
    --char:#141417;--blue:#006DB6;--blueDk:#005A99;--red:#EE413E;
    background:var(--white);
  }
  .kc{max-width:1380px;margin:0 auto;padding:0 clamp(20px,4.5vw,72px);width:100%}
  .sec{padding:clamp(72px,9vw,148px) 0;scroll-margin-top:84px}
  .sec--sm{padding:clamp(56px,7vw,104px) 0}

  /* eyebrow */
  .eye{display:inline-flex;align-items:center;gap:11px}
  .eye .tick{width:18px;height:2px;background:var(--blue);flex-shrink:0}
  .eye--red .tick{background:var(--red)}
  .eye .lbl{font-family:var(--font-mono);font-size:11.5px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--sub)}
  .eye--dark .lbl{color:rgba(255,255,255,.72)}

  .h2{margin-top:20px;font-family:var(--font-primary);font-weight:700;letter-spacing:-.026em;line-height:1.02;font-size:clamp(28px,3.5vw,50px);color:var(--ink);text-wrap:balance}
  .h2--dark{color:#fff}
  .lead{margin-top:20px;font-family:var(--font-primary);font-weight:400;font-size:clamp(16px,1.25vw,18px);line-height:1.65;color:var(--sub)}
  .lead--dark{color:rgba(255,255,255,.72)}
  .ilink{color:var(--blue);text-decoration:none;font-weight:600}

  /* buttons */
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;font-family:var(--font-primary);font-weight:600;letter-spacing:.02em;border-radius:0;cursor:pointer;text-decoration:none;white-space:nowrap;transition:background .18s,color .18s,border-color .18s}
  .btn--md{height:50px;padding:0 26px;font-size:13.5px}
  .btn--lg{height:56px;padding:0 32px;font-size:14px}
  .btn--primary{background:var(--blue);color:#fff;border:1px solid var(--blue)}
  .btn--primary:hover{background:var(--blueDk);border-color:var(--blueDk)}
  .btn--line{background:transparent;color:var(--ink);border:1px solid var(--lineStrong)}
  .btn--line:hover{background:var(--ink);color:#fff}
  .btn--line-d{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.45)}
  .btn--line-d:hover{background:rgba(255,255,255,.1)}

  .grid3{margin-top:clamp(36px,4vw,56px);display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .grid4{margin-top:clamp(36px,4vw,56px);display:grid;grid-template-columns:repeat(4,1fr);gap:16px}

  /* 1 · hero */
  .khero{position:relative;min-height:min(82vh,820px);display:flex;align-items:flex-end;background:var(--char);overflow:hidden}
  .khero__media{position:absolute;inset:0;overflow:hidden}
  .khero__media :global(img){filter:saturate(.9) contrast(1.03) brightness(.92)}
  .khero__scrim{position:absolute;inset:0;background:linear-gradient(180deg,rgba(8,8,10,.5) 0%,rgba(8,8,10,0) 30%,rgba(8,8,10,.12) 58%,rgba(8,8,10,.82) 100%)}
  .khero__inner{position:relative;z-index:2;padding-top:clamp(48px,7vh,96px);padding-bottom:clamp(48px,6vw,96px)}
  .khero__title{margin-top:24px;font-family:var(--font-primary);font-weight:700;font-size:clamp(46px,7vw,104px);letter-spacing:-.035em;line-height:.95;color:#fff;text-wrap:balance}
  .khero__lead{margin-top:26px;max-width:560px;font-family:var(--font-primary);font-weight:400;font-size:clamp(16px,1.35vw,20px);line-height:1.6;color:rgba(255,255,255,.82)}
  .khero__cta{margin-top:34px;display:flex;gap:13px;flex-wrap:wrap}
  .khero__trust{margin-top:32px;display:flex;gap:14px;flex-wrap:wrap;align-items:center}
  .khero__trust .dot{width:4px;height:4px;background:rgba(255,255,255,.4);border-radius:50%}
  .khero__trust .tlbl{font-family:var(--font-mono);font-size:11.5px;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.66)}

  /* 2 · facts */
  .fhead{display:flex;justify-content:space-between;align-items:flex-end;gap:28px;flex-wrap:wrap;margin-bottom:clamp(34px,4vw,56px)}
  .fhead__p{max-width:380px;font-family:var(--font-primary);font-weight:400;font-size:clamp(15px,1.2vw,17px);line-height:1.65;color:var(--sub)}
  .facts{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:16px}
  .fact{position:relative;background:var(--white);border:1px solid var(--line);padding:clamp(28px,2.6vw,38px) clamp(22px,2vw,28px) clamp(24px,2.2vw,30px);overflow:hidden;height:100%}
  .fact__bar{position:absolute;left:0;top:0;width:100%;height:3px}

  /* 3+9 · step cards (monochrom) */
  .stepcard{position:relative;background:var(--white);border:1px solid var(--line);padding:clamp(24px,2.2vw,34px);height:100%;display:flex;flex-direction:column;overflow:hidden;transition:border-color .25s,transform .25s,box-shadow .25s}
  .stepcard:hover{border-color:var(--lineStrong);transform:translateY(-5px);box-shadow:0 26px 46px -30px rgba(0,0,0,.45)}
  .stepcard__no{display:flex;align-items:center;justify-content:center;width:54px;height:54px;background:var(--ink);color:#fff;font-family:var(--font-primary);font-weight:700;font-size:22px;letter-spacing:-.02em;transition:background .25s}
  .stepcard:hover .stepcard__no{background:var(--blue)}
  .stepcard__t{margin-top:22px;font-family:var(--font-primary);font-size:19.5px;font-weight:600;letter-spacing:-.01em;color:var(--ink)}
  .stepcard__d{margin-top:10px;font-family:var(--font-primary);font-weight:400;font-size:14px;line-height:1.62;color:var(--sub)}

  /* 4 · benefits */
  .benefits{margin-top:clamp(36px,4vw,56px);display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .bcard{background:#1B1B20;min-height:clamp(200px,21vw,270px);padding:clamp(22px,2vw,30px);display:flex;flex-direction:column;justify-content:space-between;transition:background .2s ease}
  .bcard:hover{background:var(--blue)}
  .bcard__dia{width:13px;height:13px;flex-shrink:0;background:var(--blue);transform:rotate(45deg);transition:background .2s}
  .bcard:hover .bcard__dia{background:#fff}
  .bcard__t{font-family:var(--font-primary);font-size:clamp(17px,1.5vw,20px);font-weight:600;letter-spacing:-.01em;color:#fff}
  .bcard__d{margin-top:9px;font-family:var(--font-primary);font-weight:400;font-size:13.5px;line-height:1.55;color:rgba(255,255,255,.6);transition:color .2s}
  .bcard:hover .bcard__d{color:rgba(255,255,255,.86)}
  .benefits__note{margin-top:22px;font-family:var(--font-mono);font-size:11px;letter-spacing:.06em;color:var(--faint)}

  /* 5 · slogan */
  .kslogan{position:relative;min-height:clamp(420px,58vh,640px);display:flex;align-items:center;justify-content:center;background:var(--char);overflow:hidden;text-align:center}
  .kslogan__media{position:absolute;inset:0;overflow:hidden}
  .kslogan__media :global(img){filter:saturate(.85) contrast(1.05) brightness(.82)}
  .kslogan__scrim{position:absolute;inset:0;background:linear-gradient(180deg,rgba(8,8,10,.55) 0%,rgba(8,8,10,.32) 48%,rgba(8,8,10,.72) 100%)}
  .kslogan__inner{position:relative;z-index:2}
  .kslogan__eye{display:inline-flex;align-items:center;gap:12px;margin-bottom:24px}
  .kslogan__stroke{width:26px;height:2px;background:var(--blue)}
  .kslogan__lbl{font-family:var(--font-mono);font-size:11.5px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.8)}
  .kslogan__h2{font-family:var(--font-primary);font-weight:700;font-size:clamp(40px,6.4vw,92px);letter-spacing:-.035em;line-height:.95;color:#fff;max-width:1000px;margin:0 auto;text-wrap:balance}

  /* 6 · paths */
  .pcard{background:var(--white);border:1px solid var(--line);padding:28px 26px 30px;height:100%;display:flex;flex-direction:column;transition:border-color .2s}
  .pcard:not(.pcard--feat):hover{border-color:var(--red)}
  .pcard--feat{background:var(--char);border-color:var(--char)}
  .pcard__tag{display:inline-flex;align-items:center;gap:8px;align-self:flex-start;padding:5px 11px;background:var(--s1);border:1px solid var(--line);font-family:var(--font-mono);font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--sub)}
  .pcard--feat .pcard__tag{background:rgba(238,65,62,.18);border-color:rgba(255,255,255,.14);color:#fff}
  .pcard__dia{width:6px;height:6px;background:var(--red);transform:rotate(45deg)}
  .pcard__t{margin-top:18px;font-family:var(--font-primary);font-size:22px;font-weight:600;letter-spacing:-.015em;color:var(--ink)}
  .pcard--feat .pcard__t{color:#fff}
  .pcard__d{margin-top:11px;font-family:var(--font-primary);font-weight:400;font-size:14.5px;line-height:1.6;color:var(--sub);flex:1}
  .pcard--feat .pcard__d{color:rgba(255,255,255,.68)}
