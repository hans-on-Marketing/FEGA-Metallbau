---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import Overline from '@/components/Overline.astro';
import SectionHead from '@/components/SectionHead.astro';
import Button from '@/components/Button.astro';
import Placeholder from '@/components/Placeholder.astro';
import OptImage from '@/components/OptImage.astro';
import BrandBars from '@/components/BrandBars.astro';
import SpecList from '@/components/SpecList.astro';
import InnerHero from '@/components/InnerHero.astro';
import PageNav from '@/components/PageNav.astro';
import AdapterKonfigurator from '@/components/islands/AdapterKonfigurator.tsx';
import MietparkKonfigurator from '@/components/islands/MietparkKonfigurator.tsx';
import { C, ACCENTS } from '@/lib/theme';
import { SERVICES, COMPANY } from '@/data/content';

export function getStaticPaths() {
  return SERVICES.map((s) => ({ params: { id: s.id }, props: { s } }));
}

const { s } = Astro.props;
const accent = ACCENTS[s.accent];
const galleryCols = s.gallery.length >= 3 ? 'repeat(auto-fit,minmax(240px,1fr))' : 'repeat(2,1fr)';
---
<BaseLayout title={`${s.label} – ${COMPANY.legal}`} description={s.lead}>
  <InnerHero overline={s.label} accent={accent} title={s.headline} kicker={s.kicker} lead={s.lead} badges={s.badges}>
    <div slot="media">
      {s.hero ? (
        <div style={`position:relative;background:${s.heroDark ? C.n900 : C.n100};`}>
          <OptImage name={s.hero} dark={s.heroDark} ratio="4/3" loading="eager" fetchpriority="high" sizes="(max-width:920px) 100vw, 50vw" />
          <div style={`position:absolute;left:0;top:0;bottom:0;width:4px;background:${accent};z-index:1;`}></div>
        </div>
      ) : (
        <div class="svc-special">
          <div class="svc-special__stripe"></div>
          <div style="position:relative;">
            <div style="font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.45);">Prüfstand seit 2016</div>
            <div style="margin-top:10px;font-family:var(--font-primary);font-size:clamp(22px,3vw,34px);font-weight:600;color:#fff;line-height:1.1;">Pumpenprüfstand<br />DGUV3</div>
          </div>
          <BrandBars height={4} style="position:absolute;left:0;right:0;bottom:0;" />
        </div>
      )}
    </div>
  </InnerHero>

  <!-- Body + specs -->
  <Section sm bg={C.n25}>
    <Container>
      <div class="svc-body">
        <div>
          <Overline color={accent}>Im Detail</Overline>
          <div style="margin-top:22px;">
            {s.body.map((p) => <p class="svc-body__p">{p}</p>)}
          </div>
          {s.buyer && (
            <div class="svc-buyer" style={`border-left:3px solid ${accent};`}>
              <div style={`font-family:var(--font-mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:${accent};margin-bottom:8px;`}>Für den Einkauf</div>
              <p style="font-family:var(--font-primary);font-weight:400;font-size:15.5px;line-height:1.62;color:var(--n900);margin:0;">{s.buyer.replace('Für den Einkauf: ', '')}</p>
            </div>
          )}
        </div>
        <div>
          <div style="font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.1em;text-transform:uppercase;color:var(--n400);margin-bottom:16px;">Technische Eckdaten</div>
          <SpecList rows={s.specs} />
        </div>
      </div>
    </Container>
  </Section>

  <!-- Features -->
  <Section sm>
    <Container>
      <SectionHead overline="Leistungsumfang" max={620} accent={accent}>Was Sie von uns bekommen</SectionHead>
      <div class="svc-features">
        {s.features.map((f) => (
          <div class="svc-feature">
            <div style={`width:28px;height:3px;background:${accent};margin-bottom:18px;`}></div>
            <h3 style="font-family:var(--font-primary);font-size:19px;font-weight:500;color:var(--n900);letter-spacing:-0.01em;">{f.t}</h3>
            <p style="margin-top:10px;font-family:var(--font-primary);font-weight:300;font-size:14.5px;line-height:1.6;color:var(--n600);">{f.d}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Gallery -->
  {s.gallery.length > 0 && (
    <Section sm bg={C.n25}>
      <Container>
        <div style="margin-bottom:36px;"><Overline color={accent}>Aus der Praxis</Overline></div>
        <div style={`display:grid;grid-template-columns:${galleryCols};gap:18px;`}>
          {s.gallery.map((g) => <OptImage name={g} ratio="4/3" sizes="(max-width:920px) 100vw, 25vw" />)}
        </div>
      </Container>
    </Section>
  )}

  <!-- CTA -->
  <Section sm style="padding-top:clamp(48px,6vw,88px);padding-bottom:clamp(48px,6vw,88px);">
    <Container>
      <div class="svc-cta-row">
        <h2 class="svc-cta-row__title">{s.cta || `Interesse an ${s.label}? Sprechen Sie uns an.`}</h2>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <Button href="/kontakt" variant="primary" size="lg">Anfrage stellen</Button>
          <a href={COMPANY.phoneHref} class="svc-cta-row__phone">{COMPANY.phone}</a>
        </div>
      </div>
    </Container>
  </Section>

  {s.id === 'maschinenbau' && (
    <Section sm bg={C.n25} id="adapter-konfigurator">
      <AdapterKonfigurator client:visible />
    </Section>
  )}
  {s.id === 'mietpark' && (
    <Section sm bg={C.n25} id="konfigurator">
      <MietparkKonfigurator client:visible />
    </Section>
  )}

  <PageNav currentId={s.id} />
</BaseLayout>

<style>
  .svc-special {
    position: relative;
    background: #111;
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 36px;
    overflow: hidden;
  }
  .svc-special__stripe {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(135deg, #161616 0 16px, #1b1b1b 16px 32px);
  }
  .svc-body {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: start;
  }
  .svc-body__p {
    margin-bottom: 18px;
    font-family: var(--font-primary);
    font-weight: 300;
    font-size: clamp(16px, 1.25vw, 18px);
    line-height: 1.75;
    color: var(--n900);
    max-width: 640px;
  }
  .svc-buyer {
    margin-top: 28px;
    max-width: 640px;
    padding: 20px 24px;
    background: #fff;
  }
  .svc-features {
    margin-top: var(--block);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    border-top: 1px solid var(--n200);
  }
  .svc-feature {
    padding: 28px 28px 32px 0;
    border-bottom: 1px solid var(--n100);
    height: 100%;
  }
  .svc-cta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .svc-cta-row__title {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.2vw, 42px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.08;
    color: var(--n900);
    max-width: 620px;
    text-wrap: balance;
  }
  .svc-cta-row__phone {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0 24px;
    height: 48px;
    border: 1px solid var(--n200);
    color: var(--n900);
    text-decoration: none;
    border-radius: 2px;
  }
  @media (max-width: 920px) {
    .svc-body {
      grid-template-columns: 1fr;
    }
  }
</style>
