---
/* ============================================================================
   FEGA — Ausbildung in der Feickert-Unternehmensgruppe (Muttergesellschaft).
   Eigene Seite (aus Karriere ausgelagert). Quelle: feickert-bau.de/wir-bilden-aus/
   ========================================================================== */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Section from '@/components/Section.astro';
import Overline from '@/components/Overline.astro';
import SectionHead from '@/components/SectionHead.astro';
import Button from '@/components/Button.astro';
import Placeholder from '@/components/Placeholder.astro';
import BrandBars from '@/components/BrandBars.astro';
import { C } from '@/lib/theme';
import { AUSBILDUNG } from '@/data/content';

const a = AUSBILDUNG;
const berufeGesamt = a.standorte.reduce((n, s) => n + s.gaenge.length, 0);
const facts = [
  { v: '3', l: 'Standorte in Deutschland' },
  { v: `${berufeGesamt}`, l: 'Ausbildungsplätze' },
  { v: '4', l: 'Lehrjahre Duales Studium' },
  { v: '1.580 €', l: 'max. Vergütung / Monat' },
];
---
<BaseLayout
  title="Ausbildung bei Feickert: Bauberufe & Duales Studium (m/w/d) | FEGA"
  description="Ausbildung in der Feickert-Unternehmensgruppe (Muttergesellschaft von FEGA): Bauberufe an den Standorten Hessen, Sachsen-Anhalt und Thüringen sowie Duales Studium Bauingenieur. Jetzt Ansprechpartner finden."
>
  <!-- 1 · Hero (dunkel, cineastisch) -->
  <Section sm bg={C.n900} style="color:#fff;position:relative;overflow:hidden;">
    <BrandBars height={4} style="position:absolute;left:0;right:0;top:0;" />
    <Container>
      <div class="ah-grid">
        <div>
          <Overline onDark>{a.overline}</Overline>
          <h1 class="ah-title">Bau dir<br />was Eigenes.</h1>
          <div class="ah-parent">
            <span class="ah-parent__tag">Muttergesellschaft</span>
            <span class="ah-parent__txt">{a.parentNote}</span>
          </div>
          <p class="ah-lead">{a.lead}</p>
          <div class="ah-cta">
            <Button variant="primary" size="lg" href="#kontakt-ausbildung">Ansprechpartner finden</Button>
            <a class="ah-ghost" href={a.applyUrl}>Direkt online bewerben →</a>
          </div>
        </div>
        <div class="ah-media">
          <Placeholder label="Azubis bei Feickert" dark ratio="3/4" style="position:absolute;inset:0;" />
          <div class="ah-media__stripe"></div>
          <BrandBars height={4} style="position:absolute;left:0;right:0;bottom:0;" />
        </div>
      </div>
    </Container>
  </Section>

  <!-- 2 · Kennzahlen (dunkel) -->
  <Section sm bg="#161616" style="color:#fff;padding-top:0;">
    <Container>
      <div class="ah-facts">
        {facts.map((f, i) => (
          <div class="ah-fact">
            <div class="ah-fact__bar" style={`background:${i % 2 ? C.blue : C.red};`}></div>
            <div class="ah-fact__v" style={`color:${i === 0 ? C.blue : '#fff'};`}>{f.v}</div>
            <div class="ah-fact__l">{f.l}</div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- 3 · Dein Start in 2 Schritten -->
  <Section sm label="Dein Start">
    <Container>
      <SectionHead overline="Dein Weg zu uns" accent={C.red} max={640}
        intro="Kein langes Anschreiben, kein Bewerbungs-Marathon. Du lernst uns kennen – wir dich.">In zwei Schritten ins Team.</SectionHead>
      <div class="ah-steps">
        {a.steps.map((s, i) => (
          <div class="ah-step">
            <div class="ah-step__no" style={`color:${i % 2 ? C.blue : C.red};`}>0{i + 1}</div>
            <div>
              <h2 class="ah-step__t">{s.t}</h2>
              <p class="ah-step__d">{s.d}</p>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- 4 · Ausbildungsgänge nach Standort -->
  <Section sm bg={C.n25} label="Ausbildungsgänge">
    <Container>
      <SectionHead overline="Ausbildungsgänge nach Standort" accent={C.blue} max={640}
        intro="Drei Bundesländer, ein Handwerk: Wähle den Standort, der zu dir passt.">Wo willst du anpacken?</SectionHead>
      <div class="ah-locs">
        {a.standorte.map((st, i) => (
          <div class="ah-loc">
            <div class="ah-loc__bar" style={`background:${i % 2 ? C.blue : C.red};`}></div>
            <div class="ah-loc__head">
              <h3 class="ah-loc__region">{st.region}</h3>
              <span class="ah-loc__count">{st.gaenge.length}<span>Berufe</span></span>
            </div>
            <ul class="ah-list">
              {st.gaenge.map((g) => <li>{g}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- 5 · Duales Studium (dunkel) -->
  <Section sm bg={C.n900} style="color:#fff;position:relative;" label="Duales Studium">
    <BrandBars height={4} style="position:absolute;left:0;right:0;top:0;" />
    <Container>
      <div class="ah-dual-head">
        <Overline onDark>Noch ein Schritt weiter</Overline>
        <h2 class="ah-dual-title">{a.dual.title}</h2>
        <p class="ah-dual-lead">{a.dual.lead}</p>
      </div>
      <div class="ah-dual-grid">
        {a.dual.variants.map((v, i) => (
          <div class="ah-variant">
            <div class="ah-variant__no" style={`color:${i % 2 ? C.blue : C.red};`}>{i === 0 ? 'A' : 'B'}</div>
            <h3 class="ah-variant__t">{v.t}</h3>
            <ul class="ah-checklist">
              {v.points.map((p) => <li>{p}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- 6 · Ansprechpartner -->
  <Section sm bg={C.n25} id="kontakt-ausbildung" label="Ansprechpartner">
    <Container>
      <SectionHead overline="Kontakt" accent={C.red} max={620}
        intro="Fragen vor der Bewerbung? Ruf an oder schreib kurz – deine Ansprechpartner nach Bundesländern.">Sprich uns direkt an.</SectionHead>
      <div class="ah-contacts">
        {a.contacts.map((p, i) => (
          <div class="ah-contact">
            <div class="ah-contact__bar" style={`background:${i % 2 ? C.blue : C.red};`}></div>
            <div class="ah-contact__region">{p.region}</div>
            <div class="ah-contact__name">{p.name}</div>
            <a class="ah-contact__link" href={`mailto:${p.email}`}>{p.email}</a>
            <a class="ah-contact__link" href={`tel:${p.phone.replace(/[^0-9+]/g, '')}`}>{p.phone}</a>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- 7 · CTA -->
  <Section sm label="Ausbildung CTA">
    <Container>
      <div class="ah-cta-band">
        <h2 class="ah-cta-band__t">Dein Handwerk wartet nicht. Wir auch nicht.</h2>
        <Button variant="primary" size="lg" href={a.applyUrl}>Ausbildung bei Feickert ansehen</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .ah-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  .ah-title {
    margin-top: 22px;
    font-family: var(--font-primary);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 0.92;
    font-size: clamp(48px, 7vw, 96px);
    color: #fff;
    text-wrap: balance;
  }
  .ah-parent {
    margin-top: 24px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    max-width: 560px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.04);
    border-left: 3px solid var(--color-blue);
  }
  .ah-parent__tag {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-blue);
    padding-top: 2px;
  }
  .ah-parent__txt {
    font-family: var(--font-primary);
    font-weight: 300;
    font-size: 13.5px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.72);
  }
  .ah-lead {
    margin-top: 22px;
    max-width: 540px;
    font-family: var(--font-primary);
    font-weight: 300;
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
  }
  .ah-cta {
    margin-top: 30px;
    display: flex;
    gap: 18px;
    align-items: center;
    flex-wrap: wrap;
  }
  .ah-ghost {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    padding-bottom: 3px;
    transition: border-color 0.2s;
  }
  .ah-ghost:hover {
    border-color: #fff;
  }
  .ah-media {
    position: relative;
    aspect-ratio: 3/4;
    max-height: 460px;
  }
  .ah-media__stripe {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--color-red);
    z-index: 1;
  }

  /* ── Kennzahlen ── */
  .ah-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 16px;
  }
  .ah-fact {
    position: relative;
    background: #1c1c1c;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: clamp(26px, 2.8vw, 38px) clamp(20px, 2vw, 28px) clamp(24px, 2.4vw, 32px);
    overflow: hidden;
  }
  .ah-fact__bar {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 3px;
  }
  .ah-fact__v {
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: clamp(44px, 5.2vw, 74px);
    letter-spacing: -0.04em;
    line-height: 0.84;
  }
  .ah-fact__l {
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Schritte ── */
  .ah-steps {
    margin-top: var(--block);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }
  .ah-step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    border-top: 2px solid var(--n900);
    padding-top: 20px;
  }
  .ah-step__no {
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: clamp(40px, 4.4vw, 64px);
    letter-spacing: -0.04em;
    line-height: 0.8;
    flex-shrink: 0;
  }
  .ah-step__t {
    font-family: var(--font-primary);
    font-size: 20px;
    font-weight: 600;
    color: var(--n900);
    letter-spacing: -0.01em;
  }
  .ah-step__d {
    margin-top: 10px;
    font-family: var(--font-primary);
    font-weight: 300;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--n600);
  }

  /* ── Standorte ── */
  .ah-locs {
    margin-top: var(--block);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 18px;
  }
  .ah-loc {
    position: relative;
    background: #fff;
    border: 1px solid var(--n150);
    padding: 28px 26px 30px;
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .ah-loc:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 44px -28px rgba(0, 0, 0, 0.45);
  }
  .ah-loc__bar {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 3px;
  }
  .ah-loc__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }
  .ah-loc__region {
    font-family: var(--font-primary);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--n900);
    line-height: 1.1;
  }
  .ah-loc__count {
    flex-shrink: 0;
    text-align: right;
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 34px;
    line-height: 0.8;
    letter-spacing: -0.04em;
    color: var(--n900);
  }
  .ah-loc__count span {
    display: block;
    margin-top: 5px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--n400);
  }
  .ah-list {
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }
  .ah-list li {
    font-family: var(--font-primary);
    font-weight: 300;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--n700);
    padding: 8px 0 8px 18px;
    position: relative;
    border-bottom: 1px solid var(--n100);
  }
  .ah-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 15px;
    width: 7px;
    height: 7px;
    background: var(--color-red);
    transform: rotate(45deg);
  }

  /* ── Duales Studium ── */
  .ah-dual-head {
    max-width: 680px;
  }
  .ah-dual-title {
    margin-top: 18px;
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.2vw, 44px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.02;
    color: #fff;
    text-wrap: balance;
  }
  .ah-dual-lead {
    margin-top: 16px;
    font-family: var(--font-primary);
    font-weight: 300;
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.66);
  }
  .ah-dual-grid {
    margin-top: clamp(28px, 3.4vw, 44px);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 22px;
  }
  .ah-variant {
    position: relative;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 28px 26px 26px;
  }
  .ah-variant__no {
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 40px;
    line-height: 0.8;
    letter-spacing: -0.03em;
  }
  .ah-variant__t {
    margin-top: 14px;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.35;
    color: #fff;
  }
  .ah-checklist {
    margin: 16px 0 0;
    padding: 0;
    list-style: none;
  }
  .ah-checklist li {
    position: relative;
    font-family: var(--font-primary);
    font-weight: 300;
    font-size: 13.5px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.8);
    padding: 7px 0 7px 22px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .ah-checklist li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 7px;
    color: var(--color-blue);
    font-size: 13px;
    font-weight: 700;
  }

  /* ── Ansprechpartner ── */
  .ah-contacts {
    margin-top: var(--block);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 16px;
  }
  .ah-contact {
    position: relative;
    background: #fff;
    border: 1px solid var(--n150);
    padding: 26px 22px 26px;
    overflow: hidden;
  }
  .ah-contact__bar {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 3px;
  }
  .ah-contact__region {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--n400);
  }
  .ah-contact__name {
    margin-top: 8px;
    font-family: var(--font-primary);
    font-size: 19px;
    font-weight: 600;
    color: var(--n900);
  }
  .ah-contact__link {
    display: block;
    margin-top: 9px;
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-blue);
    text-decoration: none;
    word-break: break-word;
  }
  .ah-contact__link:hover {
    text-decoration: underline;
  }

  /* ── CTA ── */
  .ah-cta-band {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .ah-cta-band__t {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.2vw, 42px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--n900);
    max-width: 620px;
    text-wrap: balance;
  }

  @media (max-width: 920px) {
    .ah-grid {
      grid-template-columns: 1fr;
    }
    .ah-media {
      max-height: 380px;
    }
  }
</style>
