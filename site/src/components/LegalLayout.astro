---
import Container from './Container.astro';
import Section from './Section.astro';
import Overline from './Overline.astro';

interface Props {
  kicker: string;
  title: string;
  lead?: string;
  draft?: boolean;
}
const { kicker, title, lead, draft = false } = Astro.props;
---
<Section sm style="padding-top:clamp(44px,5.5vw,80px);padding-bottom:clamp(24px,3vw,40px);">
  <Container>
    <Overline>{kicker}</Overline>
    <h1 class="legal-title">{title}</h1>
    {lead && <p class="legal-lead">{lead}</p>}
    {draft && (
      <div class="legal-draft">
        <span class="legal-draft__tag">Entwurf</span>
        <span class="legal-draft__txt">Mustertext zur Orientierung – bitte vor Veröffentlichung rechtlich prüfen lassen.</span>
      </div>
    )}
  </Container>
</Section>
<Section style="padding-top:0;padding-bottom:clamp(72px,8vw,120px);">
  <Container>
    <div style="max-width:760px;"><slot /></div>
  </Container>
</Section>

<style>
  .legal-title {
    margin-top: 20px;
    font-family: var(--font-primary);
    font-weight: 700;
    letter-spacing: -0.028em;
    line-height: 1;
    font-size: clamp(34px, 4.4vw, 62px);
    color: var(--n900);
  }
  .legal-lead {
    margin-top: 20px;
    max-width: 640px;
    font-family: var(--font-primary);
    font-weight: 300;
    font-size: clamp(15px, 1.2vw, 18px);
    line-height: 1.65;
    color: var(--n600);
  }
</style>
