---
/* Optimiertes Bild (Astro Build-time-Optimierung, WebP, responsive srcset).
   Fällt auf den beschrifteten Platzhalter zurück, wenn kein Bild existiert. */
import { Image } from 'astro:assets';
import { img, widthsFor } from '@/lib/images';
import { alt as altOf } from '@/lib/alt';
import Placeholder from './Placeholder.astro';

interface Props {
  name?: string | null;
  alt?: string;
  ratio?: string;
  cover?: boolean;
  position?: string;
  class?: string;
  style?: string;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto' | 'low';
}
const {
  name,
  alt,
  ratio,
  cover = true,
  position = 'center',
  class: cls = '',
  style = '',
  sizes = '(max-width: 920px) 100vw, 50vw',
  loading = 'lazy',
  fetchpriority,
} = Astro.props;

const meta = img(name);
const a = alt ?? altOf(name);
const objStyle = `display:block;width:100%;height:100%;object-fit:${cover ? 'cover' : 'contain'};object-position:${position};${ratio ? `aspect-ratio:${ratio};` : ''}${style}`;
const extra = fetchpriority ? { fetchpriority } : {};
---
{meta ? (
  <Image
    src={meta}
    alt={a}
    widths={widthsFor(meta)}
    sizes={sizes}
    format="webp"
    loading={loading}
    decoding="async"
    class={cls}
    style={objStyle}
    {...extra}
  />
) : (
  <Placeholder label={a || name || 'Bild'} ratio={ratio} class={cls} style={style} />
)}
