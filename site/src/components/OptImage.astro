---
/* Bild-Slot. Aktuell sind die echten Fotos bewusst durch beschriftete
   Platzhalter ersetzt.
   → Fotos wieder aktivieren: unten USE_PHOTOS auf `true` setzen.
     (Die Bildoptimierung über astro:assets ist vollständig vorbereitet.) */
import { Image } from 'astro:assets';
import { img, widthsFor } from '@/lib/images';
import { alt as altOf, label as labelOf } from '@/lib/alt';
import Placeholder from './Placeholder.astro';

const USE_PHOTOS = false; // ← auf true stellen, um die echten Fotos zu zeigen

interface Props {
  name?: string | null;
  alt?: string;
  ratio?: string;
  cover?: boolean;
  position?: string;
  dark?: boolean;
  class?: string;
  style?: string;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto' | 'low';
}
const {
  name,
  alt,
  ratio,
  cover = true,
  position = 'center',
  dark = false,
  class: cls = '',
  style = '',
  sizes = '(max-width: 920px) 100vw, 50vw',
  loading = 'lazy',
  fetchpriority,
} = Astro.props;

const meta = img(name);
const a = alt ?? altOf(name);
const phLabel = labelOf(name);
const objStyle = `display:block;width:100%;height:100%;object-fit:${cover ? 'cover' : 'contain'};object-position:${position};${ratio ? `aspect-ratio:${ratio};` : ''}${style}`;
const extra = fetchpriority ? { fetchpriority } : {};
---
{USE_PHOTOS && meta ? (
  <Image
    src={meta}
    alt={a}
    widths={widthsFor(meta)}
    sizes={sizes}
    format="webp"
    loading={loading}
    decoding="async"
    class={cls}
    style={objStyle}
    {...extra}
  />
) : (
  <Placeholder label={phLabel} ratio={ratio} dark={dark} class={cls} style={`display:block;${style}`} />
)}
